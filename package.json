{
  "name": "basketball-shot-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run tests/multi-user",
    "test:emulator": "vitest run --config vitest.config.emulator.ts",
    "test:emulator:start": "firebase emulators:start --only firestore",
    "test:emulator:ci": "firebase emulators:exec --only firestore \"npm run test:emulator\"",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config e2e/playwright.config.ts --ui",
    "test:bots": "npx tsx scripts/bot-simulation.ts --emulator --bots 25",
    "test:all": "npm run test && npm run test:emulator:ci && npm run test:e2e"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^4.0.18"
  }
}
